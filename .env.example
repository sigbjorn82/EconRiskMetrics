# FRED API Key
# Get yours at: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_api_key_here

# Alpha Vantage API Key (required for AlphaVantageSource)
# Get yours at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_api_key_here

# BLS API Key (optional for BlsSource — increases rate limit from 25 to 500 req/day)
# Register free at: https://www.bls.gov/developers/home.htm
BLS_API_KEY=your_api_key_here
